# Copy this file to .env and fill in real values.
# Never commit .env — it is gitignored.

# Supabase Database Credentials
# Find these in: Supabase Dashboard -> Settings -> Database
SUPABASE_DB_HOST=
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_PORT=5432

# Path to the downloaded ODNR RBDMS CSV (only needed for import_wells.py)
CSV_FILE=Oil_And_Gas_Wells.csv

# Google Earth Engine cloud project ID (required for remote-sensing scripts)
GEE_PROJECT=

# Mapbox Tiling Service (MTS) — used by scripts/export_wells_ldgeojson.py +
# the `tilesets` CLI to publish wells / pa_oilgas tilesets.
#
# Set this in your SHELL, not here:
#     export MAPBOX_ACCESS_TOKEN="sk.eyJ1Ijoi..."   (bash)
#     $env:MAPBOX_ACCESS_TOKEN="sk.eyJ1Ijoi..."     (PowerShell)
#
# Token must be a *secret* token (sk.*) with scopes:
#     tilesets:read, tilesets:write, tilesets:list
# Mint at: https://account.mapbox.com/access-tokens
#
# We deliberately do NOT load it via python-dotenv to keep it out of
# auto-loaded process environments for unrelated scripts.
